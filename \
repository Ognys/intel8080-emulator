#include <stdio.h>
#include <stdint.h>

#include "disassembler.h"
#include "ProcessorInstructions.h"
#include "cpu.h"

int main(){

	options op = {.flags = {}, .memory = malloc(65536, sizeof(uint8_t))};

	//Reading from roms
	
	FILE *file = fopen("roms/8080EXER.COM", "rb");

	int byteRoms;
	int count = 0x0100;

	while((byteRoms = fgetc(file)) != EOF)
	{
		op.memory[count] = byteRoms;
		count++;
	}

	fclose(file);

	op.pc = 0x0100;

	while(1){

		if(op.pc == 0x0005)
		{
			if(op.c == 2)
				putchar(op.e);
			else if(op.c == 9)
			{
				uint16_t adr = op.e | (op.d << 8);

				while(op.memory[adr] != '$')
				{
					putchar(op.memory[adr]);
					adr++;
				}
			}
			else
			{
				printf("unknow call c=%02X\n",op.c);
			}

			uint16_t sp = op.sp;
			op.pc = op.memory[sp] | op.memory[sp + 1];
			op.sp += 2;
			continue;
		}

		Instructions(op);
	}


	return 0;
}
